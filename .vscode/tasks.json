{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Fabric: runClient (Gradle)",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew",
      "args": ["runClient"],
      "windows": {
        "command": "${workspaceFolder}\\gradlew.bat",
        "args": ["runClient"]
      },
      "linux": {
        "command": "${workspaceFolder}/gradlew",
        "args": ["runClient"]
      },
      "osx": {
        "command": "${workspaceFolder}/gradlew",
        "args": ["runClient"]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Fabric: regenerate VS Code launch (Gradle)",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew",
      "args": ["vscode"],
      "windows": {
        "command": "${workspaceFolder}\\gradlew.bat",
        "args": ["vscode"]
      },
      "linux": {
        "command": "${workspaceFolder}/gradlew",
        "args": ["vscode"]
      },
      "osx": {
        "command": "${workspaceFolder}/gradlew",
        "args": ["vscode"]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
